# ═══════════════════════════════════════════════════════════════════
# Save Point Finanças — .env.example
#
# Deployment: Coolify + Oracle Cloud Free Tier
#
# ┌─────────────────────────────────────────────────────────────────┐
# │ COMO USAR                                                       │
# │                                                                 │
# │  OPÇÃO A — Coolify (recomendado):                               │
# │    Configure as variáveis diretamente no painel do Coolify      │
# │    em "Environment Variables". O Coolify injeta no container.   │
# │                                                                 │
# │  OPÇÃO B — Deploy manual (SSH):                                 │
# │    cp .env.example .env                                         │
# │    nano .env  (preencha todos os CHANGE_ME)                     │
# │    docker compose up -d --build                                 │
# └─────────────────────────────────────────────────────────────────┘
#
# ⚠️  NUNCA commite o .env real no Git
# ⚠️  O .env.example é seguro para versionar (sem valores reais)
# ═══════════════════════════════════════════════════════════════════


# ── Aplicação ────────────────────────────────────────────────────────
APP_NAME=Save Point Finanças
APP_ENV=production

# Chave secreta geral — gere com: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_-hex_32

# CORS: domínio(s) que podem fazer requisições à API JSON
# Para Coolify, coloque o domínio que você definiu no painel
# Formato JSON array: ["https://meuapp.exemplo.com"]
# Múltiplos: ["https://app.exemplo.com","https://www.exemplo.com"]
ALLOWED_ORIGINS=["https://CHANGE_ME_SEU_DOMINIO"]


# ── JWT (autenticação via cookie httpOnly) ────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_-hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30


# ── PostgreSQL ────────────────────────────────────────────────────────
# Esses valores são usados TANTO pelo container do postgres
# quanto pelo app para montar a DATABASE_URL automaticamente
POSTGRES_DB=savepoint
POSTGRES_USER=savepoint
# Gere com: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
# POSTGRES_HOST é definido no docker-compose como "postgres" (nome do container)
# Não precisa definir aqui para deploy com Docker Compose


# ── Redis ────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 24
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
# REDIS_URL é montado automaticamente pelo docker-compose


# ── Cookies HTTPS ─────────────────────────────────────────────────────
# SEMPRE "true" no Coolify (que usa HTTPS por padrão)
# Mude para "false" apenas em desenvolvimento local sem HTTPS
SECURE_COOKIES=true


# ── IA — Anthropic Claude ────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
# Usado para classificação de transações (Haiku 4.5 — muito barato)
# Deixe vazio para desabilitar a classificação por IA
ANTHROPIC_API_KEY=


# ── WhatsApp Cloud API (Meta) — Opcional ─────────────────────────────
# Obtenha em: https://developers.facebook.com/
# Deixe vazio para não usar a integração WhatsApp
META_TOKEN=
META_PHONE_ID=
META_VERIFY_TOKEN=SavePoint_Verify_2024


# ── Backup automático — Backblaze B2 — Opcional ──────────────────────
# Crie um bucket e chave em: https://www.backblaze.com/b2/
# Deixe vazio para desabilitar os backups automáticos
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=savepoint-backups
BACKUP_RETENTION_DAYS=30


# ═══════════════════════════════════════════════════════════════════
# ✋ VARIÁVEIS GERENCIADAS PELO COOLIFY — NÃO EDITE AQUI
# ═══════════════════════════════════════════════════════════════════
#
# O Coolify injeta automaticamente:
#   COOLIFY_FQDN       → domínio do app (ex: app.meusite.com)
#   COOLIFY_URL        → URL completa com protocolo
#   COOLIFY_BRANCH     → branch do Git em deploy
#
# O docker-compose.yml monta automaticamente:
#   DATABASE_URL       → postgresql+asyncpg://user:pass@postgres:5432/db
#   REDIS_URL          → redis://:pass@redis:6379/0
#
# NÃO defina DATABASE_URL ou REDIS_URL aqui — eles são construídos
# no docker-compose a partir das variáveis acima para evitar duplicação.
# ═══════════════════════════════════════════════════════════════════
