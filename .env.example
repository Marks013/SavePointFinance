# ═══════════════════════════════════════════════════════════════════
# Save Point Finanças — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# Works on: ARM64 (Oracle Free) and x86_64 (VPS)
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=Save Point Finanças
APP_ENV=production
SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_32
ALLOWED_ORIGINS=["https://your-domain.com"]

# ── Database (PostgreSQL) ───────────────────────────────────────────
POSTGRES_DB=savepoint
POSTGRES_USER=savepoint
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT Auth ────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Classification (Claude / Anthropic) ──────────────────────────
ANTHROPIC_API_KEY=

# ── WhatsApp Cloud API (Meta) ───────────────────────────────────────
META_TOKEN=
META_PHONE_ID=
META_VERIFY_TOKEN=SavePoint_Verify_Token

# ── Backup (Backblaze B2) ──────────────────────────────────────────
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=savepoint-backups
BACKUP_RETENTION_DAYS=30

# ── Network ─────────────────────────────────────────────────────────
# Change to 8080 if using external reverse proxy (Caddy/Traefik) for SSL
HTTP_PORT=80
