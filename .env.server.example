# Save Point Finança
# Template de produção para Oracle Cloud + Nginx Proxy Manager + domínio próprio.
# Uso:
# 1. Copie este arquivo para `.env`
# 2. Troque todos os valores `replace-...`
# 3. No Nginx Proxy Manager, faça proxy HTTPS para http://IP_DO_SERVIDOR:3000

# Porta publicada pelo container web no servidor.
# Normalmente mantenha 3000 e deixe o HTTPS por conta do Nginx Proxy Manager.
APP_PORT=3000

# URL pública final do sistema, já com HTTPS e domínio real.
NEXT_PUBLIC_APP_URL=https://savepoint.seudominio.com.br
AUTH_URL=https://savepoint.seudominio.com.br

# Segredos obrigatórios de produção.
AUTH_SECRET=replace-with-a-long-random-auth-secret
AUTH_TRUST_HOST=true
AUTOMATION_CRON_SECRET=replace-with-a-long-random-cron-secret

# Conta principal criada/atualizada pelo bootstrap-admin.
ADMIN_EMAIL=admin@seudominio.com.br
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=Administrador Save Point
ADMIN_TENANT_NAME=Save Point
ADMIN_TENANT_SLUG=save-point

# Banco PostgreSQL interno do docker compose.
POSTGRES_DB=savepoint
POSTGRES_USER=savepoint
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# Classificação contextual opcional.
# Se não for usar, mantenha HAIKU_ENABLED=false.
HAIKU_ENABLED=false
HAIKU_API_KEY=
HAIKU_MODEL=claude-3-5-haiku-latest
HAIKU_BASE_URL=https://api.anthropic.com/v1/messages

# Assistente do WhatsApp.
# Ative apenas quando o número e o webhook já estiverem configurados.
WHATSAPP_ASSISTANT_ENABLED=false
WHATSAPP_VERIFY_TOKEN=replace-with-whatsapp-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v22.0
WHATSAPP_APP_SECRET=

# E-mail transacional.
# Recomendação para Oracle Cloud: Resend.
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@seudominio.com.br
EMAIL_FROM_NAME=Save Point Finança
EMAIL_REPLY_TO=suporte@seudominio.com.br
RESEND_API_KEY=replace-with-your-resend-api-key
BREVO_API_KEY=

# Webhooks opcionais.
# Preencha somente se você for integrar com um serviço externo próprio.
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_WHATSAPP_WEBHOOK_URL=
