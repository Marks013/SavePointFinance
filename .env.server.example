# SavePointFinance server template. Bootstrap copies this to .env.

APP_PORT=3000
NEXT_PUBLIC_APP_URL=https://example.com
AUTH_URL=https://example.com
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true
AUTOMATION_CRON_SECRET=replace-with-another-random-secret
MAINTENANCE_MODE=false
TZ=America/Sao_Paulo

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=Administrador SavePoint
ADMIN_TENANT_NAME=SavePoint
ADMIN_TENANT_SLUG=savepoint
SMOKE_USER_EMAIL=admin@example.com
SMOKE_USER_PASSWORD=replace-with-a-strong-admin-password
FAMILY_USER_EMAIL=family@example.com
FAMILY_USER_PASSWORD=replace-with-a-strong-admin-password

POSTGRES_DB=savepoint
POSTGRES_USER=savepoint
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_PORT=5432
POSTGRES_HOST_BIND=127.0.0.1

GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

WHATSAPP_ASSISTANT_ENABLED=false
WHATSAPP_VERIFY_TOKEN=replace-with-whatsapp-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_APP_SECRET=

EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=SavePointFinance
EMAIL_REPLY_TO=
SUPPORT_EMAIL_TO=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
BREVO_API_KEY=
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_WHATSAPP_WEBHOOK_URL=

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

BACKUP_CRON_SCHEDULE=0 3 * * *
BACKUP_RUN_ON_STARTUP=false
BACKUP_LOCAL_RETENTION_DAYS=14
BACKUP_CRITICAL_PATHS=README.md,web/prisma,ops
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-a-long-random-passphrase
BACKUP_ALERT_EMAIL_ENABLED=false
BACKUP_ALERT_EMAIL_TO=
BACKUP_GITHUB_ENABLED=false
BACKUP_GITHUB_TOKEN=
BACKUP_GITHUB_REPOSITORY=
BACKUP_GITHUB_RELEASE_TAG=savepoint-backups
BACKUP_GITHUB_RETENTION_COUNT=10
BACKUP_OBJECT_STORAGE_ENABLED=false
BACKUP_OBJECT_STORAGE_ENDPOINT=
BACKUP_OBJECT_STORAGE_BUCKET=
BACKUP_OBJECT_STORAGE_REGION=
BACKUP_OBJECT_STORAGE_PREFIX=
BACKUP_OBJECT_STORAGE_ACCESS_KEY=
BACKUP_OBJECT_STORAGE_SECRET_KEY=

MP_BILLING_ENABLED=false
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_BILLING_PLAN_SLUG=pro
MP_BILLING_REASON=SavePointFinance Pro
MP_BILLING_AMOUNT=29.90
MP_BILLING_ANNUAL_AMOUNT=299.00
MP_BILLING_ANNUAL_MAX_INSTALLMENTS=12
MP_BILLING_CURRENCY=BRL
MP_BILLING_FREQUENCY=1
MP_BILLING_FREQUENCY_TYPE=months
