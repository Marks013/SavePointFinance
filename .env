# ═══════════════════════════════════════════════════════════════════
# Save Point Finanças — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# Works on: ARM64 (Oracle Free) and x86_64 (VPS)
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=Save Point Finanças
APP_ENV=production
SECRET_KEY=788f0424b4f5d39803c53fd6085c2a3b94e6a76a6dcd739648ffa169c11fadfd
ALLOWED_ORIGINS=["http://161.153.204.226"]

# ── Database (PostgreSQL) ───────────────────────────────────────────
POSTGRES_DB=savepoint
POSTGRES_USER=savepoint
POSTGRES_PASSWORD=U35mOyNY

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=U35mOyNY

# ── JWT Auth ────────────────────────────────────────────────────────
JWT_SECRET_KEY=b8e6d2b983138d75d5d3009b3c41acef50176e3f84ecadff9c9342593f1f74693003e997a3086a94524389a2d76f0d774b2e2d491ddb957f7903d12480a98589
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Classification (Claude / Anthropic) ──────────────────────────
ANTHROPIC_API_KEY=

# ── WhatsApp Cloud API (Meta) ───────────────────────────────────────
META_TOKEN=
META_PHONE_ID=
META_VERIFY_TOKEN=SavePoint_Verify_Token

# ── Backup (Backblaze B2) ──────────────────────────────────────────
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=savepoint-backups
BACKUP_RETENTION_DAYS=30

# ── Network ─────────────────────────────────────────────────────────
# Change to 8080 if using external reverse proxy (Caddy/Traefik) for SSL
#HTTP_PORT=80
