# ═══════════════════════════════════════════════════════════════════
# Save Point Finanças — Environment Variables
# NEVER commit this file to version control!
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=Save Point Finanças
APP_ENV=development
SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_32
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost"]

# ── Database (PostgreSQL) ───────────────────────────────────────────
POSTGRES_DB=savepoint
POSTGRES_USER=savepoint
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://savepoint:CHANGE_ME_STRONG_PASSWORD@postgres:5432/savepoint

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS
REDIS_URL=redis://:CHANGE_ME_REDIS@redis:6379/0

# ── JWT Auth ────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Classification (Claude / Anthropic) ──────────────────────────
ANTHROPIC_API_KEY=

# ── WhatsApp Cloud API (Meta) ───────────────────────────────────────
META_TOKEN=
META_PHONE_ID=
META_VERIFY_TOKEN=SavePoint_Verify_Token

# ── Backup (Backblaze B2) ──────────────────────────────────────────
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=savepoint-backups
BACKUP_RETENTION_DAYS=30

# ── Network ─────────────────────────────────────────────────────────
HTTP_PORT=80
